package Scala {
    file "converter.scala" as converter_scala {
        object converter {
            pixelsCanvas: PixelsCanvas
            convert(commandos: String): ResultFromScala
        }
    }

    file "parser.scala" as parser_scala {
        object functions {
            parse(canvas: Canvas, str: String, defaultCommand: Command): ErrorOption

        }

        enum Command {
            draw(color: Color) 
            fill(color: Color)
        }

        class PixelsCanvas {
            ...
        }

        struct Point {
            x: Float
            y: Float
        }

        struct IntPoint {
            x: Int
            y: Int
        }

        interface Canvas {
            PixelsCanvas_methods()
        }
    }

    file "draw.scala" as draw_scala {
        object draw_functions {
            drawLine(command: Command, p1: IntPoint, p2: IntPoint): Map[(Int, Int), Color]
            drawRectangle(command: Command, p1: IntPoint, p2: IntPoint): Map[(Int, Int), Color]
            drawCircle(command: Command, p1: IntPoint, r: Int): Map[(Int, Int), Color]
        }
    }

    file "parserTest.scala" as parserTest_scala {
        class FakeCanvas {
            PixelsCanvas_methods()
        }
    }
}


