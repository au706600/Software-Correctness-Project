@startuml Overview

hide empty description

state Java {
    state Gui {
        state plot_section
        state text_commandos_section
        state error_section
    }
}

state Scala {
    state converter {
        state parser
        state draw_functions {
            state draw_boundingBox
            state drawLine
            state drawRectangle
            state drawCircle

            draw_boundingBox -[hidden]-> drawCircle
            drawLine -[hidden]-> draw_text
        }
    }
}

text_commandos_section -down-> parser: Text commandos
parser --> draw_functions: Commandos
parser -up-> error_section: Error messages
parser --> plot_section: text commandos
draw_functions -up-> plot_section: pixel data

@enduml


@startuml Sequence 
participant text_commandos_section
participant converter
participant parser
participant error_section
participant draw_functions
participant plot_section


text_commandos_section --> converter
converter --> parser
loop parse while no errors
    parser <--> draw_functions: Call: functions
end
alt error case
    converter --> error_section: Error messages
else
    converter --> plot_section: pixel data and text commandos
    
end

@enduml


